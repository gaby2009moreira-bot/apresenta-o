using System;

class Program
{
    static void Main()
    {
        for (int i = 1; i <= 10; i++)
        {
            // 1. Verificação de pulo
            if (i == 5)
                continue;

            // 2. Verificação de parada
            if (i == 8)
                break;

            // 3. Ação principal
            Console.WriteLine($"Número atual: {i}");
        }
    }
}

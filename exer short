using System;

namespace exer_if_else
{
    class Program
    {
        static void Main(string[] args)
        {
            Console.Write("Digite um número: ");
            int numero = int.Parse(Console.ReadLine());

            string resultado = (numero % 2 == 0) ? "Número par" : "Número ímpar";

            Console.WriteLine(resultado);
        }
    }
}
